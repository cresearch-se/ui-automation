# Consulting Comp App (comp-app) credentials.
# Copy this file to `.env` and fill in the values. `.env` is gitignored — never commit real creds.
# Used by apps/comp-app/auth.setup.ts to seed the SSO session.

COMP_APP_USERNAME=sowji.karumuri@cornerstone.com
COMP_APP_PASSWORD=

# GCC Compare SharePoint Permissions (gcc-sharepoint) credentials.
# Used by apps/gcc-compare-sharepoint-permissions/auth.setup.ts for scripted M365 sign-in.
# Optional: if unset, the setup falls back to fully manual login. If your account enforces MFA,
# you'll still complete the MFA prompt by hand in the headed browser either way.
GCC_SHAREPOINT_USERNAME=sowji.karumuri@cornerstone.com
GCC_SHAREPOINT_PASSWORD=
